{
  "compilerOptions": {
    "jsx": "react-jsx",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo", // Unique name
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"], // Added DOM for React
    "module": "ESNext",
 "types": ["vite/client"],

    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@hooks/*": ["src/hooks/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "include": ["src"] // IMPORTANT: Must be src, not vite.config.ts
}
